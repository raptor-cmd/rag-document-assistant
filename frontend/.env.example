# ── Frontend Environment Variables ────────────────────────────
# Las variables NEXT_PUBLIC_* son públicas y se embeben en el bundle del cliente.
# NUNCA pongas secretos en variables NEXT_PUBLIC_*.

# URL del backend FastAPI
# Dev local:   http://localhost:8000
# Producción:  https://tu-backend.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000
