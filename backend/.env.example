# ── Supabase ───────────────────────────────────────────────────
# Dev local (con Supabase CLI corriendo): http://host.docker.internal:54321
# Producción (Supabase Cloud):            https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# Service Role Key — ¡NUNCA exponer al frontend ni committear!
# Dev local:    ejecuta `supabase status` y copia "service_role key"
# Producción:   Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_KEY=

# ── OpenAI ────────────────────────────────────────────────────
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Aplicación ────────────────────────────────────────────────
# Entorno de ejecución: development | production
ENVIRONMENT=development

# Versión de la aplicación (usada en /health)
APP_VERSION=1.0.0

# Orígenes permitidos para CORS (separados por coma)
# Dev:  http://localhost:3000
# Prod: https://tu-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# ── Rate Limiting (slowapi) ───────────────────────────────────
# Formato: <número>/<periodo> — ej: 10/hour, 5/minute, 100/day
RATE_LIMIT_UPLOAD=10/hour
RATE_LIMIT_QUERY=30/hour

# ── Límites de archivo ────────────────────────────────────────
MAX_FILE_SIZE_MB=10
