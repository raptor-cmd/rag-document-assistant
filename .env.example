# ── Root .env.example ─────────────────────────────────────────
# Variables de entorno de referencia para el proyecto.
# Copia los archivos específicos de cada servicio:
#   cp backend/.env.example backend/.env
#   cp frontend/.env.example frontend/.env
# Luego rellena los valores reales en cada .env

# Variable usada por docker-compose para la URL pública del backend
NEXT_PUBLIC_API_URL=http://localhost:8000
